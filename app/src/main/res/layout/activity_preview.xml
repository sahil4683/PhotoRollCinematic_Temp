<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark"
    android:gravity="center">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_film"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tv_preview_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Generating Video..."
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_style_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Style: Ken Burns"
        android:textSize="14sp"
        android:textColor="#AAAACC"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tv_direction_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Direction: Right"
        android:textSize="14sp"
        android:textColor="#AAAACC"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tv_photo_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 photos"
        android:textSize="14sp"
        android:textColor="#AAAACC"
        android:layout_marginBottom="40dp" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_generation"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:indeterminate="false"
        android:max="100"
        android:progress="0"
        app:trackCornerRadius="8dp"
        app:indicatorColor="@color/green_generate"
        app:trackColor="#333355"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Initializing..."
        android:textSize="13sp"
        android:textColor="#8888AA"
        android:layout_marginBottom="40dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_export"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="Export Video"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/green_generate"
        app:cornerRadius="12dp"
        android:visibility="gone"
        android:layout_marginBottom="20dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="← Back"
        android:textColor="@android:color/white"
        app:backgroundTint="#333355"
        app:cornerRadius="12dp" />

</LinearLayout>
